# API endpoint that powers the widget (your Sharely-compatible backend)
VITE_API_DEFAULT_URL="https://your-api.example.com"

# Workspace identifier issued by your backend
VITE_WORKSPACE_ID=""

# Supabase project credentials (used for auth + storage)
VITE_PUBLIC_SUPABASE_URL=""
VITE_PUBLIC_SUPABASE_ANON_KEY=""

# OAuth/redirect URL — typically your deployed app URL
VITE_REDIRECT_URL="https://your-app.example.com"
